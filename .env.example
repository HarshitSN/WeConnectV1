# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional override (default: gemini-2.5-flash). For this demo flow, keep flash variants for low latency.
# GEMINI_MODEL=gemini-2.5-flash
# Optional hard timeout per Gemini request in milliseconds (prevents hung voice/vision turns).
# GEMINI_CALL_TIMEOUT_MS=12000
# Optional cooldown after quota exhaustion before attempting Gemini again.
# GEMINI_QUOTA_COOLDOWN_MS=60000
# Optional model fallback chain (tried left->right before demo fallback).
# If left empty, the app auto-appends safe defaults:
# gemini-2.0-flash,gemini-2.0-flash-lite
# GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.0-flash,gemini-2.0-flash-lite

# Optional but recommended for discover fallback quality:
# SerpApi (Google engine)
SERPAPI_API_KEY=

# Optional chain anchoring mode:
# - demo: always use simulated tx hash
# - auto: try real chain, fallback to demo on config/provider/send failure
# - real: require real chain success (no fallback)
CHAIN_MODE=auto

# Base Sepolia defaults (required for CHAIN_MODE=real, optional for auto)
CHAIN_RPC_URL=
CHAIN_PRIVATE_KEY=
CHAIN_ID=84532

# Optional contract anchoring (when set, anchor route calls contract instead of tx-data self-call)
CHAIN_CONTRACT_ADDRESS=
